      "name": "vw_credit_card_expenses",
      "isExisting": false,
      "definition": "select \"id\", \"name\", \"description\", \"value\", \"parcelas\", \"date\", \"is_paid\", \"is_income\", \"category_id\", \"period_id\", \"payment_method_id\", \"created_at\", \"updated_at\" from \"operation\" where (\"operation\".\"payment_method_id\" = 3 and \n    date(\"operation\".\"date\", 'unixepoch', '-3 hours') >= date('now', '-3 hours', 'start of month')\n    AND date(\"operation\".\"date\", 'unixepoch', '-3 hours') < date('now', '-3 hours', '+1 month', 'start of month')\n  )"
